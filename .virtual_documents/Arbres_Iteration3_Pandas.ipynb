# Fonction pour trouver le maire en fonction de l'année
def maire_de_l_annee(annee):
    # on filtre le DataFrame des maires
    m = df_maires[(df_maires['debut'] <= annee) & (df_maires['fin'] >= annee)]
    return m['nom'].values[0]  # récupère le nom du maire

# Appliquer la fonction sur df_arbres
df_arbres['maire'] = df_arbres['Annee'].apply(maire_de_l_annee)

